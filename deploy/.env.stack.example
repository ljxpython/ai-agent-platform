# Full-stack container deployment env template
#
# Shared Postgres instance:
# - runtime_service
# - platform_api_v2
# - interaction_data_service
#
# Runtime image baseline:
# PYTHON_VERSION=3.13

# Shared image/build baseline
PYTHON_VERSION=3.13
RUNTIME_SERVICE_IMAGE=aitestlab-runtime-service:local
PLATFORM_API_V2_IMAGE=aitestlab-platform-api-v2:local
INTERACTION_DATA_SERVICE_IMAGE=aitestlab-interaction-data-service:local
PLATFORM_WEB_VUE_IMAGE=aitestlab-platform-web-vue:local

# Exposed host ports
RUNTIME_SERVICE_PORT=8123
INTERACTION_DATA_SERVICE_PORT=8081
PLATFORM_API_V2_PORT=2142
PLATFORM_WEB_VUE_PORT=3000
NGINX_PORT=80

# Shared Postgres
SHARED_POSTGRES_HOST=postgres
SHARED_POSTGRES_PORT=5432
SHARED_POSTGRES_SUPERUSER=postgres
SHARED_POSTGRES_SUPERUSER_PASSWORD=postgres
RUNTIME_POSTGRES_DB=runtime_service
RUNTIME_POSTGRES_USER=runtime_service
RUNTIME_POSTGRES_PASSWORD=runtime_service
PLATFORM_API_V2_POSTGRES_DB=platform_api_v2
PLATFORM_API_V2_POSTGRES_USER=platform_api_v2
PLATFORM_API_V2_POSTGRES_PASSWORD=platform_api_v2
INTERACTION_DATA_SERVICE_POSTGRES_DB=interaction_data_service
INTERACTION_DATA_SERVICE_POSTGRES_USER=interaction_data_service
INTERACTION_DATA_SERVICE_POSTGRES_PASSWORD=interaction_data_service

# Shared Redis
SHARED_REDIS_HOST=redis
SHARED_REDIS_PORT=6379
RUNTIME_REDIS_DB=0
PLATFORM_API_V2_REDIS_DB=1

# Runtime-service env baseline
APP_ENV=test
MODEL_ID=
BG_JOB_ISOLATED_LOOPS=true
SYSTEM_PROMPT=
# Shared MultimodalMiddleware parser model default for container deployment
MULTIMODAL_PARSER_MODEL_ID=gpt_5.4-ccr
ENABLE_TOOLS=
TOOLS=
MEMORY_BACKEND=
STORE_BACKEND=
PERSISTENCE_PROFILE=
MIDDLEWARES=

# Runtime private knowledge MCP defaults
TEST_CASE_V2_KNOWLEDGE_MCP_ENABLED=
TEST_CASE_V2_KNOWLEDGE_MCP_URL=
TEST_CASE_V2_KNOWLEDGE_TIMEOUT_SECONDS=
TEST_CASE_V2_KNOWLEDGE_SSE_READ_TIMEOUT_SECONDS=

# Recommended examples:
# - service runs on host machine:
#   TEST_CASE_V2_KNOWLEDGE_MCP_URL=http://host.docker.internal:8621/sse
# - service runs on public/internal reachable host:
#   TEST_CASE_V2_KNOWLEDGE_MCP_URL=https://mcp.example.com/sse

# Optional runtime auth values
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_TIMEOUT_SECONDS=

# Runtime -> interaction-data-service persistence
INTERACTION_DATA_SERVICE_TOKEN=
INTERACTION_DATA_SERVICE_TIMEOUT_SECONDS=10

# LangGraph Lite mode for runtime-service
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGGRAPH_CLOUD_LICENSE_KEY=

# Platform API V2 env baseline
PLATFORM_API_V2_APP_ENV=local
PLATFORM_API_V2_API_DOCS_ENABLED=true
PLATFORM_API_V2_CORS_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
PLATFORM_API_V2_AUTH_REQUIRED=true
PLATFORM_API_V2_JWT_ACCESS_SECRET=change-me-access-secret
PLATFORM_API_V2_JWT_REFRESH_SECRET=change-me-refresh-secret
PLATFORM_API_V2_BOOTSTRAP_ADMIN_ENABLED=true
PLATFORM_API_V2_BOOTSTRAP_ADMIN_USERNAME=admin
PLATFORM_API_V2_BOOTSTRAP_ADMIN_PASSWORD=admin123456
PLATFORM_API_V2_LANGGRAPH_UPSTREAM_API_KEY=
PLATFORM_API_V2_LANGGRAPH_GRAPH_SOURCE_ROOT=
PLATFORM_API_V2_INTERACTION_DATA_SERVICE_TOKEN=
PLATFORM_API_V2_INTERACTION_DATA_SERVICE_TIMEOUT_SECONDS=30

# Optional platform-facing external RAG / LightRAG HTTP
PLATFORM_API_V2_KNOWLEDGE_UPSTREAM_URL=
PLATFORM_API_V2_KNOWLEDGE_UPSTREAM_API_KEY=
PLATFORM_API_V2_KNOWLEDGE_UPSTREAM_TIMEOUT_SECONDS=60

# Recommended examples:
# - service runs on host machine:
#   PLATFORM_API_V2_KNOWLEDGE_UPSTREAM_URL=http://host.docker.internal:9621
# - service runs on public/internal reachable host:
#   PLATFORM_API_V2_KNOWLEDGE_UPSTREAM_URL=https://rag.example.com

# Interaction-data-service env baseline
API_DOCS_ENABLED=true
SERVICE_CORS_ALLOW_ORIGINS=*
SERVICE_NAME=interaction-data-service
SERVICE_VERSION=0.1.0
INTERACTION_DB_ENABLED=true
INTERACTION_DB_AUTO_CREATE=true
DOCUMENT_ASSET_ROOT=./storage

# Frontend env baseline
VITE_APP_NAME=Agent Platform
VITE_PLATFORM_API_V2_RUNTIME_ENABLED=true
VITE_REQUEST_TIMEOUT_MS=30000
VITE_DEV_PORT=3000
VITE_DEV_PROXY_TARGET=http://platform-api-v2:2142
VITE_LANGGRAPH_DEBUG_URL=

# Frontend API bases for no-nginx stack
VITE_PLATFORM_API_URL_DIRECT=http://localhost:2142
VITE_PLATFORM_API_V2_URL_DIRECT=http://localhost:2142

# Frontend API bases for nginx stack
VITE_PLATFORM_API_URL_INGRESS=/
VITE_PLATFORM_API_V2_URL_INGRESS=/
