APP_ENV=test
# Leave MODEL_ID empty to use conf/settings.yaml -> <env>.default_model_id.
# Only set MODEL_ID to a model key that actually exists in conf/settings.yaml.
MODEL_ID=
# Deep agents rely on synchronous filesystem access in some backends. Keep
# background jobs on isolated loops to avoid langgraph dev blockbuster failures.
BG_JOB_ISOLATED_LOOPS=true

# model group secrets used by conf/settings.yaml
MASS_URL=https://example.openai-compatible.com/v1
MASS_GLM_4_MODEL=glm-4
MASS_KIMI_KEY=your_api_key_here

# Optional runtime defaults
# SYSTEM_PROMPT=
# MULTIMODAL_PARSER_MODEL_ID=iflow_qwen3-vl-plus
# MEMORY_BACKEND=memory
# STORE_BACKEND=memory
# PERSISTENCE_PROFILE=test
# MIDDLEWARES=message_sanitizer,tool_error_guard

# Production only
# POSTGRES_DSN=postgresql://user:pass@host:5432/dbname
# REDIS_URL=redis://host:6379/0
