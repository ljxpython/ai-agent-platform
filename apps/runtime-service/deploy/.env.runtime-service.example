# Runtime-service single-app container deployment env template
#
# Python baseline for the runtime image:
# PYTHON_VERSION=3.13
#
# This file is for deploy-time env wiring.
# Real model credentials still belong in:
# - apps/runtime-service/runtime_service/.env
# - apps/runtime-service/runtime_service/conf/settings.local.yaml

# Image/build
PYTHON_VERSION=3.13
RUNTIME_SERVICE_IMAGE=aitestlab-runtime-service:local

# Ports
RUNTIME_SERVICE_PORT=8123

# Runtime dependencies
RUNTIME_POSTGRES_HOST=postgres
RUNTIME_POSTGRES_PORT=5432
RUNTIME_POSTGRES_DB=runtime_service
RUNTIME_POSTGRES_USER=runtime_service
RUNTIME_POSTGRES_PASSWORD=runtime_service
RUNTIME_REDIS_HOST=redis
RUNTIME_REDIS_PORT=6379
RUNTIME_REDIS_DB=0

# Runtime env baseline
APP_ENV=test
MODEL_ID=
BG_JOB_ISOLATED_LOOPS=true

# Optional runtime defaults
SYSTEM_PROMPT=
# Shared MultimodalMiddleware parser model default
MULTIMODAL_PARSER_MODEL_ID=gpt_5.4-ccr
ENABLE_TOOLS=
TOOLS=
MEMORY_BACKEND=
STORE_BACKEND=
PERSISTENCE_PROFILE=
MIDDLEWARES=

# Optional service-private knowledge MCP defaults
TEST_CASE_V2_KNOWLEDGE_MCP_ENABLED=
TEST_CASE_V2_KNOWLEDGE_MCP_URL=
TEST_CASE_V2_KNOWLEDGE_TIMEOUT_SECONDS=
TEST_CASE_V2_KNOWLEDGE_SSE_READ_TIMEOUT_SECONDS=

# Recommended examples:
# - service runs on host machine:
#   TEST_CASE_V2_KNOWLEDGE_MCP_URL=http://host.docker.internal:8621/sse
# - service runs on public/internal reachable host:
#   TEST_CASE_V2_KNOWLEDGE_MCP_URL=https://mcp.example.com/sse

# Optional auth mode inputs
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_TIMEOUT_SECONDS=

# Optional remote persistence target for test_case_service / test_case_service_v2
# Example when interaction-data-service runs on the host:
# INTERACTION_DATA_SERVICE_URL=http://host.docker.internal:8081
INTERACTION_DATA_SERVICE_URL=
INTERACTION_DATA_SERVICE_TOKEN=
INTERACTION_DATA_SERVICE_TIMEOUT_SECONDS=10

# Optional extra tracing/upstream values
#
# Lite mode:
# - provide LANGSMITH_API_KEY
# - leave LANGGRAPH_CLOUD_LICENSE_KEY empty
# - LANGSMITH_ENDPOINT should point to the public or self-hosted LangSmith base URL
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGGRAPH_CLOUD_LICENSE_KEY=
