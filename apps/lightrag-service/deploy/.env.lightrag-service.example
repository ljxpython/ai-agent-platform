# Compose-only overrides for apps/lightrag-service
# Also copy any required model / embedding / auth settings from ../.env.example
# into this file before running `docker compose up`.

LIGHTRAG_HTTP_PORT=9621
LIGHTRAG_MCP_PORT=8621

HOST=0.0.0.0
PORT=9621
WORKING_DIR=/app/data/rag_storage
INPUT_DIR=/app/data/inputs
TIKTOKEN_CACHE_DIR=/app/data/tiktoken

MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8621
MCP_PATH=/sse
MCP_MESSAGE_PATH=/messages/
MCP_SHOW_BANNER=false
MCP_LOG_LEVEL=INFO
LIGHTRAG_MCP_STORAGE_ROOT=/app/data/rag_storage
LIGHTRAG_MCP_INPUT_ROOT=/app/data/inputs
