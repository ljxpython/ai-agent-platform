PLATFORM_API_V2_APP_NAME=Platform API V2
PLATFORM_API_V2_APP_VERSION=0.2.0
PLATFORM_API_V2_APP_ENV=local
PLATFORM_API_V2_API_DOCS_ENABLED=true
PLATFORM_API_V2_CORS_ALLOW_ORIGINS=["http://localhost:3000"]

PLATFORM_API_V2_LANGGRAPH_UPSTREAM_URL=http://127.0.0.1:8123
PLATFORM_API_V2_LANGGRAPH_UPSTREAM_TIMEOUT_SECONDS=60
PLATFORM_API_V2_INTERACTION_DATA_SERVICE_URL=http://127.0.0.1:8081

PLATFORM_API_V2_PLATFORM_DB_ENABLED=true
PLATFORM_API_V2_PLATFORM_DB_AUTO_CREATE=true
PLATFORM_API_V2_DATABASE_URL=sqlite+pysqlite:///./.data/platform-api-v2.db

PLATFORM_API_V2_OPERATIONS_QUEUE_BACKEND=db_polling
PLATFORM_API_V2_OPERATIONS_WORKER_POLL_INTERVAL_SECONDS=1
PLATFORM_API_V2_OPERATIONS_WORKER_IDLE_SLEEP_SECONDS=2

PLATFORM_API_V2_AUTH_REQUIRED=true
PLATFORM_API_V2_JWT_ACCESS_SECRET=change-me-access-secret
PLATFORM_API_V2_JWT_REFRESH_SECRET=change-me-refresh-secret
PLATFORM_API_V2_BOOTSTRAP_ADMIN_ENABLED=true
PLATFORM_API_V2_BOOTSTRAP_ADMIN_USERNAME=admin
PLATFORM_API_V2_BOOTSTRAP_ADMIN_PASSWORD=admin123456
