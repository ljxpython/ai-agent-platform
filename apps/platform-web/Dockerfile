FROM node:22-alpine AS build

WORKDIR /app

ARG VITE_APP_NAME=Agent\ Platform
ARG VITE_PLATFORM_API_URL=/
ARG VITE_PLATFORM_API_RUNTIME_ENABLED=true
ARG VITE_REQUEST_TIMEOUT_MS=30000
ARG VITE_DEV_PORT=3000
ARG VITE_DEV_PROXY_TARGET=http://localhost:2142
ARG VITE_LANGGRAPH_DEBUG_URL=

ENV VITE_APP_NAME=$VITE_APP_NAME \
    VITE_PLATFORM_API_URL=$VITE_PLATFORM_API_URL \
    VITE_PLATFORM_API_RUNTIME_ENABLED=$VITE_PLATFORM_API_RUNTIME_ENABLED \
    VITE_REQUEST_TIMEOUT_MS=$VITE_REQUEST_TIMEOUT_MS \
    VITE_DEV_PORT=$VITE_DEV_PORT \
    VITE_DEV_PROXY_TARGET=$VITE_DEV_PROXY_TARGET \
    VITE_LANGGRAPH_DEBUG_URL=$VITE_LANGGRAPH_DEBUG_URL

COPY package.json pnpm-lock.yaml ./
RUN corepack enable && pnpm install --frozen-lockfile

COPY . .
RUN pnpm build

FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx/default.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
