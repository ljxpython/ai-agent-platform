{
  "name": "platform-web-vue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.17.0 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('node:fs');for(const dir of ['dist','coverage','.vite']){fs.rmSync(dir,{recursive:true,force:true,maxRetries:5,retryDelay:100});}\"",
    "lint": "eslint \"src/**/*.{ts,tsx,vue}\" \"eslint.config.js\" \"vite.config.ts\" \"vitest.config.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,vue}\" \"eslint.config.js\" \"vite.config.ts\" \"vitest.config.ts\" --fix",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@langchain/langgraph-sdk": "1.0.0",
    "@tanstack/vue-virtual": "^3.13.12",
    "@vueuse/core": "^10.11.1",
    "axios": "^1.8.4",
    "markdown-it": "^14.1.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.5.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/jsdom": "^21.1.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.18",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^17.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.31.1",
    "vite": "^5.4.11",
    "vite-plugin-checker": "^0.8.0",
    "vitest": "^2.1.9",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "pnpm@10.5.1"
}
